# =============================================================================
# Etherscan API keys
# ETHERSCAN_API_KEY is the V2 unified key — read by hardhat.config.ts etherscan
# block and works across all chains. The per-network keys below are kept only
# for legacy/standalone tooling that still expects them.
# =============================================================================
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=
BASESCAN_API_KEY=
DRPC_API_KEY=

PRIVATE_KEY=

# OpenZeppelin Defender Configuration
DEFENDER_API_KEY=your_api_key_here
DEFENDER_API_SECRET=your_api_secret_here
DEFENDER_RELAYER_ADDRESS=0x...
DEFENDER_SAFE_ADDRESS=0x...
DEFENDER_AUTO_APPROVE=false
DEFENDER_VIA_TYPE=EOA
DEFENDER_GAS_LIMIT=5000000
DEFENDER_MAX_GAS_PRICE=50000000000

# =============================================================================
# Per-chain RPC + block explorer (HARDHAT NETWORK MODE)
# Used by: `npx hardhat run <script> --network <chain>` and `verify:verify`.
# hardhat.config.ts reads each *_RPC into its network block. *_BLOCK_EXPLORER_URL
# are reference values for the operator — the etherscan api/browser URLs used for
# verification are hardcoded in hardhat.config.ts, not read from here.
# =============================================================================
MAINNET_RPC=
MAINNET_BLOCK_EXPLORER_URL=https://etherscan.io
SEPOLIA_RPC=
SEPOLIA_BLOCK_EXPLORER_URL=https://sepolia.etherscan.io
POLYGON_RPC=
POLYGON_BLOCK_EXPLORER_URL=https://polygonscan.com
POLYGON_AMOY_RPC=
POLYGON_AMOY_BLOCK_EXPLORER_URL=https://amoy.polygonscan.com
BASE_RPC=
BASE_BLOCK_EXPLORER_URL=https://basescan.org
BASE_SEPOLIA_RPC=
BASE_SEPOLIA_BLOCK_EXPLORER_URL=https://sepolia.basescan.org
BSC_RPC=
BSC_BLOCK_EXPLORER_URL=https://bscscan.com
BSC_TESTNET_RPC=
BSC_TESTNET_BLOCK_EXPLORER_URL=https://testnet.bscscan.com

# Optional fork pinning (per-chain block numbers, read by hardhat.config.ts)
# MAINNET_BLOCK=
# SEPOLIA_BLOCK=
# POLYGON_BLOCK=
# POLYGON_AMOY_BLOCK=
# BASE_BLOCK=
# BASE_SEPOLIA_BLOCK=
# BSC_BLOCK=
# BSC_TESTNET_BLOCK=

# =============================================================================
# Standalone RPC deployer mode (NOT hardhat --network)
# Used by: scripts/setup/RPCDiamondDeployer.ts, scripts/deploy/rpc/*,
# scripts/safe/confirmDeployment.ts — points the standalone deployer at ONE
# chain at a time. NOTE: RPC_URL does NOT populate the hardhat --network urls
# above; for `npx hardhat run --network <chain>` set the matching *_RPC var.
# =============================================================================
DIAMOND_NAME=GeniusDiamond
RPC_URL=
NETWORK_NAME=
CHAIN_ID=
DIAMOND_CONFIG_PATH=diamonds/GeniusDiamond/geniusdiamond.config.json
DEPLOYMENTS_PATH=diamonds
CONTRACTS_PATH=contracts
GAS_LIMIT_MULTIPLIER=1.2
MAX_RETRIES=3
RETRY_DELAY_MS=2000
VERBOSE=true
WRITE_DEPLOYED_DIAMOND_DATA=true

# Safe proposal mode for Diamond upgrades
SAFE_PROPOSE=false
SAFE_ADDRESS=
SAFE_PROPOSER_PRIVATE_KEY=
SAFE_TX_SERVICE_URL=
SAFE_API_KEY=
SAFE_ORIGIN=gnus-ai-rpc-upgrade

JB_IDE_HOST=on

# USED AS THE DEFAULT FOR MULTICHAIN FORKS
HH_CHAIN_ID=31337

# Single Hardhat chain fork
# FORK_URL=
# FORK_BLOCK_NUMBER=
