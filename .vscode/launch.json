{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Unit Tests",
            "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**/*.js"],
            "program": "${workspaceFolder}/test/index.ts",
            "preLaunchTask": "tsc: build - tsconfig.json",
            "outFiles": ["${workspaceFolder}/dist/**/*.js"],
            "resolveSourceMapLocations": ["${workspaceFolder}/dist/**/*.js", "${workspaceFolder}/**/*.ts"],
            "sourceMaps": true,
            "smartStep": true,
            // "stopOnEntry": true,
            "trace": true
        },
        {
            "name": "Multichain Plugin Test",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "tsc: build - tsconfig.json",
            "outFiles": ["${workspaceFolder}/dist/**/*.js"],
            "program": "${workspaceFolder}/node_modules/hardhat/internal/cli/cli.js",
            "args": [ 
                "test-multichain", 
                "./test/integration/multichain/tests/MultiChainForkDeployTests.ts",
                "./test/integration/multichain/tests/MultiChainGNUSBridgeTests.ts",
                "./test/integration/multichain/tests/MultiChainGNUSERC20Tests.ts",             
                "./test/integration/multichain/tests/MultiChainErc20BatchTests.ts",
                "--chains", "sepolia", "--logs", "logs"],
            "runtimeArgs": [ "--preserve-symlinks" ],
            "skipFiles": [
                "<node_internals>/**", 
                "${workspaceFolder}/node_modules/**/*.js", 
            ],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/dist/**/*.js", 
                "${workspaceFolder}/**/*.ts",
            ],
            "sourceMaps": true,
            "smartStep": true,
            "console": "integratedTerminal",
        },
        {
            "name": "Multichain Plugin Sepolia,Amoy Test",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "tsc: build - tsconfig.json",
            "outFiles": ["${workspaceFolder}/dist/**/*.js"],
            "program": "${workspaceFolder}/node_modules/hardhat/internal/cli/cli.js",
            "args": [ 
                "test-multichain", 
                "./test/integration/multichain/tests/MultiChainForkDeployTests.ts",
                "./test/integration/multichain/tests/MultiChainGNUSBridgeTests.ts",                
                "./test/integration/multichain/tests/MultiChainGNUSERC20Tests.ts",             
                "./test/integration/multichain/tests/MultiChainErc20BatchTests.ts", 
                "--chains", "polygon_amoy,sepolia", "--logs", "logs"],
            "runtimeArgs": [ "--preserve-symlinks" ],
            "skipFiles": [
                "<node_internals>/**", 
                "${workspaceFolder}/node_modules/**/*.js", 
            ],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/dist/**/*.js", 
                "${workspaceFolder}/**/*.ts",
            ],
            "sourceMaps": true,
            "smartStep": true,
            "console": "integratedTerminal",
        },
    ]
}